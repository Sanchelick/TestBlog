<% currently_at "Список пользователей" %>

<h2 class="title ml-5 mt-3">Список пользователей:</h2>
<table class="table is-stripped ml-5" style="width: 97%">
  <thead>
    <th>ID</th>
    <th>Имя</th>
    <th>Почта</th>
    <th>Зарегестрирован</th>
  </thead>
  <% @users.each do |user| %>
    <%= render "user", user: user %>
  <% end %>
</table>
<div style="display: flex; height: 4vh;" class="ml-5">
  <%= link_to "Выгрузить пользователей", admin_users_index_path(format: :zip), class: 'button is-link' %>
  <%= form_with url: admin_users_path do |f| %>
    <div class="zip-uploader">
      <div class="file has-name">
	<span class="file-cta ml-3">
	  <span class="file-icon" style="width: 10vw;">
	    <%= f.label :archive, 'Выбрать файл...', class: 'file-label' %>
 	    <%= f.file_field :archive, class: "file-input" %>
	  </span>
	</span>
	<span class="file-name"> <%= params[:archive]&.file_name || "..." %> </span>
      </div>
      <%= f.submit "Загрузить пользователей из файла", class: "button is-primary" %>
    </div>
  <% end %>
</div>

<%= params %>
