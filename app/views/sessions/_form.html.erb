<%= form_with url: sessions_path do |f| %>
  <div class="field">
    <%= f.label :email, value: params[:email], class: "label" %>
    <div class="control">
      <%= f.text_field :email, class: "input" %>
    </div>
  </div>
  <div class="field">
    <%= f.label :password, class: "label" %>
    <div class="control">
      <%= f.password_field :password, class: "input" %>
    </div>
  </div>
  <div class="checkbox">
    <%= f.check_box :remember_me, class: "checkbox", value: "1" %>
    <%= f.label "Запомнить мения", class: "checkbox" %>
  </div>
  <div class="control">
    <%= f.submit 'Войти', class: 'button is-link' %>
  </div>
<% end %>
