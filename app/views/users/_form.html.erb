<turbo-frame id="login_form">
  <div class="mr-5 ml-5">
    
    <%= form_with model: @user, local: true do |f| %>
      <%= render "shared/errors", object: @user%>
      
      <div class="field">
	<%= f.label "Имя пользователя", class: "label" %>
	<div class="control">
	  <%= f.text_field :name, class: "input" %>
	</div>
	
      </div>
      <div class="field">
	<%= f.label "Электронная почта", class: "label" %>
	<div class="control">
	  <%= f.text_field :email, class: "input" %>
	</div>
	
      </div>
      <div class="field">
	<%= f.label "Пароль", class: "label" %>
	<div class="control">
	  <%= f.password_field :password, class: "input" %>
	</div>
	
      </div>
      <div class="field">
	<%= f.label "Подтверждение пароля", class: "label" %>
	<div class="control">
	  <%= f.password_field :password_confirmation, class: "input" %>
	</div>
      </div>
      
      <% unless @user.new_record? %>
	<div class="field">
	  <%= f.label "Прежний пароль", class: "label" %>
	  <div class="control">
	    <%= f.password_field :old_password, class: "input" %>
	  </div>
	</div>
      <% end %>
      
      <div class="control">
	<%= f.submit (@user.new_record? ? 'Зарегистрироваться' : 'Сохранить'), class: 'button is-link' %>
      </div>
    <% end %>
  </div> 
</turbo-frame>
